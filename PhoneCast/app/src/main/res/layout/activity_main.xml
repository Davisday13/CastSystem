<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#0C0F17"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📡 PhoneCast"
        android:textColor="#00E5FF"
        android:textSize="32sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-condensed"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Servidor de Espejo de Pantalla"
        android:textColor="#707E94"
        android:textSize="14sp"
        android:layout_marginBottom="32dp"/>

    <!-- Tarjeta de Dirección IP -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#161B26"
        android:padding="16dp"
        android:layout_marginBottom="16dp">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DIRECCIÓN DEL SERVIDOR"
            android:textColor="#50617A"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>
            
        <TextView
            android:id="@+id/tv_my_ip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📱 IP: buscando..."
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Tarjeta de Control de Accesibilidad (Toques remotos) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#161B26"
        android:padding="16dp"
        android:layout_marginBottom="24dp">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SERVICIO DE ACCESIBILIDAD"
            android:textColor="#50617A"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_accessibility_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔴 Desactivado"
                android:textColor="#FF5252"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btn_enable_accessibility"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Activar"
                android:textSize="12sp"
                android:textColor="#0C0F17"
                android:backgroundTint="#00E5FF"
                android:paddingHorizontal="12dp"
                android:paddingVertical="0dp"/>
        </LinearLayout>
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Requerido para que la radio pueda tocar la pantalla del teléfono."
            android:textColor="#50617A"
            android:textSize="11sp"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

    <!-- Indicador de Estado de Transmisión -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔴 Detenido"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FF5252"
        android:layout_marginBottom="24dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Botones de Acción -->
    <Button
        android:id="@+id/btn_start"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="▶ INICIAR TRANSMISIÓN"
        android:textColor="#0C0F17"
        android:backgroundTint="#00E5FF"
        android:textStyle="bold"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_stop"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="⏹ DETENER TRANSMISIÓN"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF5252"
        android:textStyle="bold"
        android:textSize="16sp"
        android:visibility="gone"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💡 Abre la app RadioCast en la radio para conectarte."
        android:textColor="#50617A"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

</LinearLayout>
