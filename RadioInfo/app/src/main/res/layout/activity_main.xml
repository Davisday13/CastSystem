<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#0C0F17"
    android:padding="8dp">

    <!-- Left panel: info categories -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📡 RadioInfo"
            android:textColor="#00E5FF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/ll_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </ScrollView>

        <Button
            android:id="@+id/btn_refresh"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="🔄 Actualizar"
            android:textColor="#0C0F17"
            android:backgroundTint="#00E5FF"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btn_test_connection"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="🌐 Probar conexión PhoneCast"
            android:textColor="#FFFFFF"
            android:backgroundTint="#50617A"
            android:textStyle="bold"
            android:layout_marginTop="4dp" />

        <Button
            android:id="@+id/btn_save_report"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="💾 Guardar reporte"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4CAF50"
            android:textStyle="bold"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Right panel: detailed log / connection test -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#161B26"
        android:padding="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋 Diagnóstico / Log"
            android:textColor="#00E5FF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_log"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="Presiona &quot;Actualizar&quot; para escanear el radio..."
            android:textColor="#707E94"
            android:textSize="12sp"
            android:typeface="monospace"
            android:gravity="top"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>

</LinearLayout>
